<html>
    <head><style>

body{
    margin:0;
    padding:0;
    font-family:Arial, sans-serif;
    background: linear-gradient(to bottom, #ff9a9e, #fad0c4);
    color:#fff;
}

/* Menu container */
body{
    text-align:center;
    padding-top:40px;
}

/* Links styling */
a{
    display:block;
    margin:15px auto;
    width:180px;
    text-decoration:none;
    background:linear-gradient(to right, #ff6b81, #ff9472);
    color:white;
    padding:12px;
    border-radius:10px;
    font-size:16px;
    font-weight:bold;
    transition:0.3s;
    box-shadow:0 5px 15px rgba(0,0,0,0.2);
}

/* Hover effect */
a:hover{
    transform:scale(1.05);
    background:linear-gradient(to right, #ff4d6d, #ff7f50);
    box-shadow:0 8px 20px rgba(0,0,0,0.3);
}

/* Remove default underline spacing issues */
h1{
    margin:0;
}

</style></head>
